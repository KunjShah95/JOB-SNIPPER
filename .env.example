# JobSniper AI - Environment Configuration
# Copy this file to .env and add your API keys

# Optional: AI API Keys (for enhanced functionality)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

# Note: The application works in demo mode without any API keys
# API keys are only needed for enhanced AI-powered features

















